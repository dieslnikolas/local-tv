# ═══════════════════════════════════════════════
#  Environment config – copy to .env and edit!
#  cp .env.example .env
# ═══════════════════════════════════════════════

# Timezone
TZ=Europe/Prague

# Local IP address of this server
# Linux:   ip a  (look for 192.168.x.x under your network interface)
# Windows: ipconfig  (look for "IPv4 Address" under WiFi or Ethernet)
HOST_IP=192.168.xxx.yyy

# ───────────────────────────────────────────────
#  Media directory  (absolute path)
#  All containers mount this as /data
#
#  Recommended structure (Trash Guides):
#    /data/
#    ├── media/
#    │   ├── movies/    ← Radarr root folder / Jellyfin Movies library
#    │   └── tv/        ← Sonarr root folder / Jellyfin TV Shows library
#    └── torrents/
#        ├── movies/    ← qBittorrent category "movies"
#        └── tv/        ← qBittorrent category "tv"
#
#  Keeping downloads and media under the same /data root ensures hardlinks work,
#  so Radarr/Sonarr can instantly import without copying the file.
#  See: https://trash-guides.info/File-and-Folder-Structure/Hardlinks-and-Instant-Moves/
#
#  Linux:    /mnt/media   or   /home/your-name/local-tv/media
#  Windows:  D:/Media     or   C:/Users/name/Videos
# ───────────────────────────────────────────────
MEDIA_DIR=/home/your-name/local-tv/media

# ───────────────────────────────────────────────
#  Config directory  (absolute path)
#  Where service configs (databases, settings) are stored.
#  Always use an absolute path — a relative ./config depends on
#  where docker compose is invoked from, which may not be predictable.
#
#  Linux:    /home/your-name/local-tv/config
#  Windows:  C:/local-tv/config
# ───────────────────────────────────────────────
CONFIG_DIR=/home/your-name/local-tv/config

# ───────────────────────────────────────────────
#  Ports – host-side port for each service
#  Change if something is already using a port
# ───────────────────────────────────────────────

PORT_JELLYFIN=8096
PORT_JELLYFIN_DISCOVERY=7359
PORT_JELLYFIN_DLNA=1900
PORT_QBITTORRENT=8080
PORT_TORRENT=6881
PORT_GLANCES=61208
PORT_FLARESOLVERR=8191
PORT_PROWLARR=9696
PORT_RADARR=7878
PORT_SONARR=8989
PORT_BAZARR=6767
PORT_HOMEPAGE=3000
PORT_FILEBROWSER=8081

# ───────────────────────────────────────────────
#  API keys for Homepage dashboard widgets
#  See README for where to find each key
# ───────────────────────────────────────────────

# Radarr → Settings → General → Security → API Key
RADARR_API_KEY=

# Sonarr → Settings → General → Security → API Key
SONARR_API_KEY=

# Prowlarr → Settings → General → Security → API Key
PROWLARR_API_KEY=

# Jellyfin → Dashboard → API Keys → add new
JELLYFIN_API_KEY=

# qBittorrent WebUI password — used by Homepage dashboard widget to show stats.
# Set it in qBittorrent: Settings → Web UI → Authentication → password
QBIT_PASSWORD=

# Bazarr → Settings → General → Security → API Key
BAZARR_API_KEY=

# ───────────────────────────────────────────────
#  System user IDs
#  Used by linuxserver.io images to run processes as your user
#  so files created by containers are owned by you, not root.
#
#  Linux:   id -u  and  id -g  → usually 1000 on first user account
#  Windows: leave as 1000 (Docker Desktop ignores these anyway)
# ───────────────────────────────────────────────
PUID=1000
PGID=1000
